{
    "name": "budgetcontrol/elasticsearch",
    "description": "A library to manage elasticsearch queries and results in a more efficient way",
    "type": "package",
    "license": "AGPL",
    "repositories": {
        "budgetcontrol/cryptable" : {
            "type":"vcs",
            "url":"git@github.com:BudgetControl/LibsCryptable.git"
        },
        "budgetcontrol/library" : {
            "type":"vcs",
            "url":"https://github.com/BudgetControl/Library.git"
        }
    },
    "require": {
        "php": "^8.1",
        "elasticsearch/elasticsearch": "~8.19",
        "budgetcontrol/library": "~1.4.6"
    },
    "autoload": {
        "psr-4": {
            "BudgetcontrolLibs\\ElasticSearch\\": "libs/"
        }
    },
    "authors": [
        {
            "name": "Marco De Felice",
            "email": "marco.defelice@mlabfactory.it"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "echo-env": "echo 'ELASTICSEARCH_INDEX=index-name' && echo 'ELASTICSEARCH_HOST=host-name' && echo 'ELASTICSEARCH_USERNAME=elastic' && echo 'ELASTICSEARCH_PASSWORD=the-password'"
    }
}
